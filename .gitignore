# ==============================
#   PulseChat — Root .gitignore
# ==============================

# Dependencies
node_modules/
**/node_modules/

# Environment files
.env
.env.local
.env.development
.env.production
**/.env
**/.env.local

# Logs
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# OS files
.DS_Store
Thumbs.db
desktop.ini

# IDE / Editor
.vscode/
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?

# Build outputs
dist/
build/

# Uploads (user uploaded files)
pulsechat-server/uploads/*
!pulsechat-server/uploads/.gitkeep